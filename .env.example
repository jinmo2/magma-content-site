# ── 발행 API (POST /api/posts) 설정 ─────────────────────────────
# 발행 API 인증 키 — 긴 임의 문자열을 직접 만들어 넣으세요.
#   생성 예: openssl rand -hex 32
PUBLISH_API_KEY=

# GitHub fine-grained PAT — "이 저장소 한정 + Contents: Read and write" 권한만 부여하세요.
# 로컬 개발에서는 비워 두면 content/<collection>/ 에 파일을 직접 씁니다 (dev 폴백).
GITHUB_TOKEN=

# 커밋 대상 저장소 (계정/저장소이름)
# 중요: 수강생 배포에서는 dandacompany/... 가 아니라 본인 GitHub repo 여야 합니다.
GITHUB_REPO=your-account/magma-content-site

# 선택: 대시보드 iframe URL을 특정 호스트로 제한하고 싶을 때만 사용합니다.
# 예: lookerstudio.google.com,public.tableau.com
NEXT_PUBLIC_DASHBOARD_HOST_ALLOWLIST=
